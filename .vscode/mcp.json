{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "grep_app": {
      "command": "node",
      "args": [
        "scripts/grep-mcp.js"
      ]
    },
    "postgres-memory": {
      "command": "node",
      "args": [
        "scripts/postgres-mcp.js"
      ]
    },
    "atom8n": {
      "command": "node",
      "args": [
        "external/mcp-inspector-atom8n/build/index.js"
      ],
      "env": {
        "N8N_API_URL": "http://localhost:5678",
        "N8N_API_KEY": "${N8N_API_KEY}"
      }
    }
  }
}