# Copy this file to .env and fill in values you actually need.
# Empty/missing keys disable the corresponding provider — the UI will
# automatically hide unavailable ones.

# ---------------------------------------------------------------------------
# PostgreSQL (Context Bridge — semantic search store)
# ---------------------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ai_memory
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# n8n (Phase H — workflow execution; not required for prompt recipes)
# ---------------------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
NODE_ENV=production
WEBHOOK_URL=http://localhost:5678/
N8N_API_KEY=
AI_BACKEND_TYPE=gemini

# ---------------------------------------------------------------------------
# LLM providers — recipes pick one via execution.model: "<provider>/<model_id>"
# Bare model ids ("gemma-3-4b") default to the local provider.
# ---------------------------------------------------------------------------

# local — llama-swap / llama.cpp / Ollama / vLLM / LM Studio (OpenAI-compatible)
LLAMA_SWAP_URL=http://localhost:11434/v1
# Legacy aliases (still honored): OPENAI_API_BASE, OPENAI_API_KEY
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=local-no-auth

# gemini — Google Generative Language API (OpenAI-compat shim)
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# anthropic — Claude via the Messages API
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Default model used when a recipe doesn't declare execution.model.
# Format: "<provider>/<model_id>" or a bare local model id.
RECIPE_DEFAULT_MODEL=gemma-3-4b

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
GRAPHIFY_MODEL=llama3
