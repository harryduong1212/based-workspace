# =============================================================================
# .env.example — copy to `.env` and fill in.
# `.env` is gitignored. NEVER paste real secrets in this file.
# For randomizable values (POSTGRES_PASSWORD, N8N_API_KEY, N8N_ENCRYPTION_KEY),
# run `./scripts/gen_secrets.sh` and paste its output.
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL (shared by Context Bridge + n8n via infrastructure/core compose)
# Host port is configurable so it can coexist with other Postgres on the host.
# ---------------------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=          # ./scripts/gen_secrets.sh
POSTGRES_DB=ai_memory
POSTGRES_PORT=5432          # change if 5432 already taken on the host
POSTGRES_HOST=localhost

# ---------------------------------------------------------------------------
# n8n (Phase H — workflow execution)
# N8N_ENCRYPTION_KEY: n8n encrypts stored credentials with this. If lost,
# every credential in the n8n UI becomes unreadable. Set explicitly so it
# survives `podman volume rm`.
# ---------------------------------------------------------------------------
N8N_HOST=localhost
N8N_PORT=5678
NODE_ENV=production
WEBHOOK_URL=http://localhost:5678/
N8N_API_KEY=                       # paste from n8n UI (Settings → API → Create API Key)
N8N_ENCRYPTION_KEY=                # ./scripts/gen_secrets.sh
N8N_USER_MANAGEMENT_JWT_SECRET=    # ./scripts/gen_secrets.sh — keeps API keys valid across restarts

# ---------------------------------------------------------------------------
# LLM providers — recipes pick one via execution.model: "<provider>/<model_id>"
# Bare model ids ("gemma-3-4b") default to the local provider.
# ---------------------------------------------------------------------------
# local — llama-swap / llama.cpp / Ollama / vLLM / LM Studio (OpenAI-compatible)
LLAMA_SWAP_URL=http://localhost:11434/v1
OPENAI_API_BASE=http://localhost:11434/v1
OPENAI_API_KEY=local-no-auth

# gemini — Google Generative Language API (OpenAI-compat shim)
# Paste from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# anthropic — Claude via Messages API
# Paste from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Default model used when a recipe doesn't declare execution.model.
# Format: "<provider>/<model_id>" or a bare local model id.
RECIPE_DEFAULT_MODEL=gemma-3-4b
AI_BACKEND_TYPE=gemini

# ---------------------------------------------------------------------------
# External SaaS connectors (live-probed via services/control_panel/connector_probes.py)
# ---------------------------------------------------------------------------
# Gmail — app password (Google Account → Security → 2-Step → App passwords)
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# GitHub — PAT (https://github.com/settings/tokens) with repo scope
GITHUB_TOKEN=

# Jira Cloud — API token (https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Bitbucket Cloud — app password (Personal settings → App passwords)
BITBUCKET_USERNAME=
BITBUCKET_APP_PASSWORD=

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
GRAPHIFY_MODEL=llama3
